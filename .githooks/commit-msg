#!/bin/sh
# Enforce Conventional Commits on the subject line.
# Enable locally with: git config core.hooksPath .githooks

msg_file="$1"
subject=$(head -n 1 "$msg_file")

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9-]+\))?!?: .+$'

if ! printf '%s' "$subject" | grep -Eq "$pattern"; then
  {
    echo "Invalid commit subject:"
    echo "  $subject"
    echo "Expected: <type>(<scope>)?: <description>"
    echo "Types: feat fix docs style refactor perf test build ci chore revert"
  } >&2
  exit 1
fi

if [ "${#subject}" -gt 72 ]; then
  echo "Commit subject exceeds 72 characters: $subject" >&2
  exit 1
fi
